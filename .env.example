# ── GCP (required for Vertex AI, Firestore, Logging, Trace) ─────
# Vertex AI uses Application Default Credentials via service account
# NO API KEYS NEEDED — auth is IAM-based
GOOGLE_CLOUD_PROJECT=your-gcp-project-id

# ── App config ───────────────────────────────────────────────────
FIRESTORE_COLLECTION=footprints
GEMINI_API_KEY=your-gemini-api-key-here

# ── Frontend ─────────────────────────────────────────────────────
VITE_API_BASE_URL=/api

# ── Local dev only: run 'gcloud auth application-default login' ──
# This lets Vertex AI work locally without a service account key file
